NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Viewer policy: production should be true. Set false only for local seed browsing.
REQUIRE_LOGIN_TO_VIEW=true

# Google OAuth. Production authentication is Google-only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Sheets source of truth. On Cloud Run, Application Default Credentials
# from the attached runtime service account are used automatically.
GOOGLE_SHEETS_ID=

# Optional local/dev service account fallback. If one is set, set both.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
